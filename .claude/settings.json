{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "agent": "manager",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/orchestration-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git rev-parse *)",
      "Bash(git commit *)",
      "Bash(git add *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git merge *)",
      "Bash(pwd)",
      "Bash(ls *)",
      "Bash(la *)",
      "Bash(ll *)",
      "Bash(tree *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(bun run lint *)",
      "Bash(bun test *)",
      "Bash(bun run test *)",
      "Bash(npm run lint *)",
      "Bash(npm test *)",
      "Bash(pnpm lint *)",
      "Bash(pnpm test *)",
      "Bash(pytest *)",
      "Bash(ruff check *)",
      "Bash(tsc *)",
      "Bash(bun run:*)",
      "Bash(bunx tsc:*)",
      "Bash(bunx syncpack lint *)",
      "Bash(bun install *)",
      "Bash(bun remove *)",
      "Bash(gh api:*)",
      "Skill(team-pipeline)",
      "Bash(ls:*)",
      "Bash(git worktree:*)",
      "Bash(git branch:*)",
      "Bash(curl -s http://localhost:3000/vehicles)",
      "Bash(bunx biome:*)",
      "Bash(git:*)",
      "Bash(bunx drizzle-kit:*)",
      "mcp__chrome-devtools__list_console_messages",
      "mcp__chrome-devtools__take_screenshot",
      "mcp__chrome-devtools__navigate_page",
      "mcp__stitch__list_projects",
