    ],
    "deny": [
      "Bash(rm *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(kubectl *)",
      "Bash(terraform *)",
      "Bash(git push *)",
      "Bash(git reset *)",
      "Bash(git clean *)",
